{
    "name": "@sikandarmoyaldev/light-render",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "lint": "eslint .",
        "build": "pnpm -r run build",
        "format": "prettier --write .",
        "dev": "pnpm -r --parallel run dev",
        "example:render": "pnpm --filter @light-render/example-cli run render",
        "example:preview": "pnpm --filter @light-render/example-preview run dev"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "typescript-eslint": "^8.60.1"
    }
}
